# Server
PORT=5000
NODE_ENV=development

# Email (SMTP) - for sending verification and MFA codes
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Frontend URL (for CORS and Stripe redirects)
FRONTEND_URL=http://localhost:5173

# PostgreSQL Database (AWS RDS)
# Replace these with your actual RDS values after creating the instance
DB_HOST=paperstudio-db.cebow4ykixrs.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=paperstudio_db
DB_USER=paper_admin
DB_PASSWORD=Pikachupetz123

# JWT Secret (change this to a random string)
JWT_SECRET=paperstudio_jwt_secret_change_me_in_production

# AWS S3 (for product image uploads)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
